<?xml version="1.0"?>
<!-- 平衡车 URDF 骨架 - 阶段 2 按 3D 建模实际尺寸补全
     TF 树: base_link -> laser / imu_link / camera_link
     尺寸常量与 docs/serial-protocol.md 常量表保持一致 -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="balance_bot">

  <xacro:property name="wheel_diameter" value="0.067"/> <!-- m, 待实测 -->
  <xacro:property name="wheel_track"    value="0.170"/> <!-- m, 待实测 -->

  <link name="base_link">
    <!-- TODO(阶段2): 车体外形（可用简单 box 近似） -->
  </link>

  <link name="laser"/>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/> <!-- TODO: 按雷达实际安装位置 -->
  </joint>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/> <!-- TODO: 按 MPU6050 实际安装位置/方向 -->
  </joint>

</robot>
